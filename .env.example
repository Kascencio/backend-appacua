# =====================================================
# Backend – Variables de entorno (Producción / Dokploy)
# =====================================================
# Copiar a .env y rellenar con valores reales.
# NO commitear este archivo con secretos reales.
# =====================================================

# ── General ──────────────────────────────────────────
NODE_ENV=production
PORT=3100
HOST=0.0.0.0

# ── Base de datos ────────────────────────────────────
# En docker-compose.prod.yml el host interno es "db"
DATABASE_URL=mysql://aqua_user:CAMBIAR_PASSWORD@db:3306/aqua_sonda

# ── JWT ──────────────────────────────────────────────
# Generar con: openssl rand -base64 48
JWT_SECRET=CAMBIAR_SECRETO_JWT
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Cookies ──────────────────────────────────────────
# Dominio padre para compartir cookie entre subdominios
# Ejemplo: .midominio.com (con punto al inicio)
COOKIE_DOMAIN=.midominio.com

# URL del frontend (usada para CORS)
FRONTEND_URL=https://app.midominio.com

# ── Telegram (Opcional) ──────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_BASE_URL=

# ── Sensor API Key (Opcional) ────────────────────────
SENSOR_INGEST_API_KEY=
