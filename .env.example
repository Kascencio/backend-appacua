NODE_ENV=production
PORT=3300
HOST=0.0.0.0
JWT_SECRET=change_me
# Si MySQL está en el host (fuera de Docker), usa la IP/hostname real del servidor MySQL.
# Si usas docker-compose.mysql.yml, usa host mysql:
# DATABASE_URL=mysql://user:pass@mysql:3306/aqua_sonda
DATABASE_URL=mysql://user:pass@127.0.0.1:3306/aqua_sonda
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
