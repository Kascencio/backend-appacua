DOCKER_IMAGE=docker.io/TU_USUARIO/aqua-backend:latest
NODE_ENV=production
PORT=3100
# Si MySQL corre en el host del VPS (fuera de Docker):
DATABASE_URL=mysql://usuario:password@host.docker.internal:3306/aqua_sonda
# Si MySQL corre como servicio en el mismo stack:
# DATABASE_URL=mysql://usuario:password@mysql:3306/aqua_sonda
JWT_SECRET=REEMPLAZA_CON_UN_SECRETO_LARGO
JWT_EXPIRES_IN=24h
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_WEBHOOK_SECRET=
SENSOR_INGEST_API_KEY=
